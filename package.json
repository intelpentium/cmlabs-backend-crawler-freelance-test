{
  "name": "cmlabs-crawler-api",
  "version": "1.0.0",
  "description": "REST API service for crawling modern websites with Fastify, Prisma, PostgreSQL, and Playwright.",
  "main": "dist/server.js",
  "license": "ISC",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "crawl:targets": "tsx src/scripts/crawl-targets.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@prisma/client": "^6.16.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.6.0",
    "playwright": "^1.56.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "prisma": "^6.16.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
