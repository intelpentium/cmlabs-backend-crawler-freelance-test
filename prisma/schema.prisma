generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CrawlResult {
  id        String   @id @default(uuid())
  url       String
  title     String?
  metadata  Json
  filePath  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([url])
}
